# ─────────────────────────────────────────────────────────────────────────────
# Gerador de áudios de Omniterapia — configuração
#
# Você NÃO precisa editar este arquivo na mão. Ao abrir o app pela primeira vez,
# uma tela de configuração vai pedir as chaves e gravar tudo automaticamente.
# Este exemplo existe só para referência (e pra quem prefere editar manualmente).
#
# Copie este arquivo para ".env" e preencha as chaves.
# ─────────────────────────────────────────────────────────────────────────────

# OBRIGATÓRIA — é a voz (síntese de fala). Pegue em: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# ROTEIRO — basta UMA destas (a IA que escreve o texto da omniterapia).
# Recomendado: Google AI Studio (tem plano gratuito). https://aistudio.google.com/apikey
GOOGLE_AI_STUDIO_API_KEY=

# Alternativas de roteiro (opcionais — só se não usar o Google):
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Opcionais (têm padrão, não precisa mexer)
# ─────────────────────────────────────────────────────────────────────────────
# Porta local (padrão: 7791)
# PORT=7791
